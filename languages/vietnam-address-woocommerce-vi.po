#. translators: %s: URL to the rate manager page
#: includes/class-vncheckout-shipping-method.php:85
#, php-format
msgid ""
"Configure shipping rates by region, province, district, and ward on the <a "
"href=\"%s\" style=\"font-weight:600\">Shipping Rates</a> page (WooCommerce → "
"Shipping Rates)."
msgstr "Cấu hình cước phí vận chuyển theo vùng, tỉnh, quận và phường trên trang <a href=\"%s\" style=\"font-weight:600\">Cước phí vận chuyển</a> (WooCommerce → Cước phí vận chuyển)."

