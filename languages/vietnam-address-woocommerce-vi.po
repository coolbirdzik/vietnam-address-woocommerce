#: includes/class-coolbirdzik-shipping-admin.php:50
#: includes/class-vncheckout-shipping-admin.php:40
msgid "Shipping Rates"
msgstr "Cước phí vận chuyển"

#: includes/class-coolbirdzik-shipping-admin.php:69
msgid ""
"Vietnam Shipping Rates: frontend assets not found. Run `npm run build` "
"inside the frontend/ directory."
msgstr "Cước phí vận chuyển Việt Nam: không tìm thấy tài nguyên frontend. Hãy chạy `npm run build` trong thư mục frontend/."

#: includes/class-vncheckout-region-manager.php:125
msgid "Region name and code are required."
msgstr "Tên vùng và mã vùng là bắt buộc."

#: includes/class-vncheckout-region-manager.php:145
msgid "Predefined regions cannot be modified."
msgstr "Các vùng định sẵn không thể sửa đổi."

#: includes/class-vncheckout-region-manager.php:154
msgid "A region with that code already exists."
msgstr "Một vùng với mã này đã tồn tại."

#: includes/class-vncheckout-region-manager.php:179
msgid "Region not found."
msgstr "Không tìm thấy vùng."

#: includes/class-vncheckout-region-manager.php:183
msgid "Predefined regions cannot be deleted."
msgstr "Các vùng định sẵn không thể xóa."

#: includes/class-vncheckout-shipping-method.php:31
msgid "Vietnam Shipping Calculator"
msgstr "Tính phí vận chuyển Việt Nam"

#: includes/class-vncheckout-shipping-method.php:33
msgid ""
"Shipping fees based on Vietnam province/district/ward, order total, and "
"weight."
msgstr "Phí vận chuyển dựa trên tỉnh/quận/phường, tổng đơn hàng và cân nặng."

